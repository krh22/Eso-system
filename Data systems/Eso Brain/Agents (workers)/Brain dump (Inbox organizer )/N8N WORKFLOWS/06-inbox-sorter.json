{
  "name": "06-inbox-sorter",
  "nodes": [
    {
      "name": "Watch Inbox File (trigger)",
      "type": "n8n-nodes-base.localFileTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "name": "Read Inbox Content",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "name": "Extract Unsorted Entries",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [650, 300]
    },
    {
      "name": "Ollama Classify (via tinyllama)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [850, 300]
    },
    {
      "name": "Parse JSON Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [1050, 300]
    },
    {
      "name": "Route to Domain File",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [1250, 300]
    },
    {
      "name": "Add to Checklist (if task)",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [1450, 300]
    },
    {
      "name": "Write to Change Log",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [1650, 300]
    },
    {
      "name": "Write to System Log",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [1850, 300]
    },
    {
      "name": "Mark Entry as [SORTED]",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [2050, 300]
    }
  ],
  "connections": {
    "Watch Inbox File (trigger)": {
      "main": [
        [
          {
            "node": "Read Inbox Content",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Read Inbox Content": {
      "main": [
        [
          {
            "node": "Extract Unsorted Entries",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Extract Unsorted Entries": {
      "main": [
        [
          {
            "node": "Ollama Classify (via tinyllama)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Ollama Classify (via tinyllama)": {
      "main": [
        [
          {
            "node": "Parse JSON Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse JSON Response": {
      "main": [
        [
          {
            "node": "Route to Domain File",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Route to Domain File": {
      "main": [
        [
          {
            "node": "Add to Checklist (if task)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Add to Checklist (if task)": {
      "main": [
        [
          {
            "node": "Write to Change Log",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Write to Change Log": {
      "main": [
        [
          {
            "node": "Write to System Log",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Write to System Log": {
      "main": [
        [
          {
            "node": "Mark Entry as [SORTED]",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "saveExecutionProgress": true,
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "meta": {
    "templateId": "inbox-sorter-06",
    "description": "Watches Universal Inbox.md for changes -> reads content -> extracts unsorted entries -> sends to Ollama (tinyllama) for classification -> routes to domain files -> adds [SORTED] tag -> logs everything."
  }
}
